#!/usr/bin/env bash
# cartopian-devin — Cartopian wrapper for the Devin CLI.
#
# Usage:  cartopian-devin <absolute-prompt-path>
#
# Reads the prompt file and passes its content to `devin -p` with
# non-interactive flags. Edit the Configuration section below to change
# permission mode and other tool-specific settings.
#
# Exit codes:
#   0   — devin completed successfully
#   1   — wrapper error (missing file, missing CLI, bad arguments)
#   *   — upstream devin exit code

set -euo pipefail

# --- Configuration ---------------------------------------------------
# Permission mode (per `devin --help`): "normal" | "dangerous" | "bypass"
#   normal     — ask before write/execute operations
#   dangerous  — auto-approve write/execute operations
#   bypass     — auto-approve all tool calls (full autonomy)
# Default is "bypass" so devin runs non-interactively, matching the
# autonomy posture of cartopian-codex (workspace-write sandbox),
# cartopian-claude (--dangerously-skip-permissions), and
# cartopian-gemini (--approval-mode yolo). The PM→assignee handoff
# contract requires the assignee to complete without TTY interaction;
# if autonomy is not desired for a given role, do not run that role in
# auto mode.
# Note: "accept-edits", "plan", and "autonomous" are interactive slash
# commands inside a session, not values for the --permission-mode flag.
DEVIN_PERMISSION_MODE="${CARTOPIAN_DEVIN_PERMISSION:-bypass}"
# ------------------------------------------------------------------

readonly PROMPT_PATH="${1:-}"

if [[ -z "$PROMPT_PATH" ]]; then
  echo "cartopian-devin: error: missing prompt path argument" >&2
  echo "usage: cartopian-devin <absolute-prompt-path>" >&2
  exit 1
fi

if [[ ! -f "$PROMPT_PATH" ]]; then
  echo "cartopian-devin: error: prompt file not found: $PROMPT_PATH" >&2
  exit 1
fi

if ! command -v devin &>/dev/null; then
  echo "cartopian-devin: error: 'devin' not found in PATH" >&2
  echo "Install: https://docs.devin.ai/" >&2
  exit 1
fi

PROMPT_CONTENT="$(cat "$PROMPT_PATH")"

# --- Launch directory ------------------------------------------------
# FR-012: assignee CLIs run with cwd set to the Cartopian project root
# (the registered project path). Prompts always live at
# <workspace>/projects/<project-id>/prompts/PROMPT-*.md, so the project
# root is derivable from the prompt path alone.
#
# Override: set CARTOPIAN_LAUNCH_CWD to an absolute or relative path to
# skip auto-resolution. Useful for split-layout, cross-drive, monorepo,
# or per-repo-sandbox setups. A non-existent path is a hard error, not
# a silent fallback.
if [[ -n "${CARTOPIAN_LAUNCH_CWD:-}" ]]; then
  if [[ ! -d "$CARTOPIAN_LAUNCH_CWD" ]]; then
    echo "cartopian-devin: CARTOPIAN_LAUNCH_CWD='$CARTOPIAN_LAUNCH_CWD' is not a directory" >&2
    exit 1
  fi
  LAUNCH_CWD="$(cd "$CARTOPIAN_LAUNCH_CWD" && pwd)"
  cd "$LAUNCH_CWD"
  echo "cartopian-devin: cwd=$LAUNCH_CWD (CARTOPIAN_LAUNCH_CWD override)" >&2
else
  PROMPT_ABS="$(cd "$(dirname "$PROMPT_PATH")" && pwd)/$(basename "$PROMPT_PATH")"
  PROMPTS_DIR="$(dirname "$PROMPT_ABS")"
  PROJECT_DIR="$(dirname "$PROMPTS_DIR")"
  # FR-012 launch-cwd: trigger when basename("$PROMPTS_DIR")) == "prompts"
  if [[ "$(basename "$PROMPTS_DIR")" == "prompts" ]]; then
    cd "$PROJECT_DIR"
    echo "cartopian-devin: cwd=$PROJECT_DIR" >&2
  else
    echo "cartopian-devin: prompt is outside a Cartopian project layout; leaving cwd unchanged (set CARTOPIAN_LAUNCH_CWD to override)" >&2
  fi
fi
# --------------------------------------------------------------------

# --- Access grants (OQ-009) -----------------------------------------
# Read resolved work-root absolute paths via Core CLI. Fail-closed when
# non-empty and per-tool sandbox cannot scope multi-root access. Allow an
# explicit per-invocation bypass via CARTOPIAN_DEVIN_UNRESTRICTED=true.
if command -v cartopian &>/dev/null; then
  RC_JSON="$(cartopian resolve-config "$PWD" | head -n 1)"
  if [[ -n "$RC_JSON" ]]; then
    WORK_ROOTS=$(python3 - <<'PY'
import sys, json
try:
    rec = json.loads(sys.stdin.read())
except Exception:
    print("")
    raise SystemExit(0)
wr = rec.get("work_roots") or {}
if isinstance(wr, dict) and wr:
    print("\n".join(str(p) for p in wr.values()))
else:
    print("")
PY
    <<<"$RC_JSON")
    if [[ -n "$WORK_ROOTS" ]]; then
      while IFS= read -r root; do
        [[ -z "$root" ]] && continue
        if [[ ! -d "$root" ]]; then
          echo "[work-root] missing: $root" >&2
          exit 1
        fi
      done <<< "$WORK_ROOTS"
      if [[ "${CARTOPIAN_DEVIN_UNRESTRICTED:-false}" != "true" ]]; then
        echo "[work-root] tool cannot scope multi-root access; set CARTOPIAN_DEVIN_UNRESTRICTED=true to bypass (dangerous)" >&2
        exit 1
      else
        echo "cartopian-devin: unrestricted mode enabled; proceeding without scoped grants" >&2
      fi
    fi
  fi
fi
# --------------------------------------------------------------------

# Build the command
CMD=(devin -p)
CMD+=(--permission-mode "$DEVIN_PERMISSION_MODE")
CMD+=("--" "$PROMPT_CONTENT")

echo "cartopian-devin: running devin -p (permission=$DEVIN_PERMISSION_MODE)" >&2
exec "${CMD[@]}"
