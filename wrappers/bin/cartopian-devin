#!/usr/bin/env bash
# cartopian-devin — Cartopian wrapper for the Devin CLI.
#
# Usage:  cartopian-devin <absolute-prompt-path>
#
# Passes the prompt file path to `devin -p --prompt-file` with
# non-interactive flags. Edit the Configuration section below to change
# permission mode and other tool-specific settings.
#
# Exit codes:
#   0   — devin completed successfully
#   1   — wrapper error (missing file, missing CLI, bad arguments)
#   *   — upstream devin exit code

set -euo pipefail

# --- Status-file helper (early-crash signal for wait-handoff) --------
# Source the shared helper that emits <report-path>.status on assignee
# exit. Optional: if the helper is missing, degrade to no-op stubs so the
# wrapper still runs (the status file is never a hard requirement).
_CARTOPIAN_WRAPPER_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
if [[ -f "${_CARTOPIAN_WRAPPER_DIR}/_cartopian-status.sh" ]]; then
  # shellcheck source=_cartopian-status.sh
  source "${_CARTOPIAN_WRAPPER_DIR}/_cartopian-status.sh"
else
  cartopian_status_path() { echo ""; }
  cartopian_write_status() { return 0; }
  cartopian_report_complete() { return 1; }
  cartopian_run_supervised() { shift; "$@"; CARTOPIAN_ASSIGNEE_EXIT=$?; return 0; }
fi
# --------------------------------------------------------------------

# --- Configuration ---------------------------------------------------
# CARTOPIAN_DEVIN_PERMISSION selects an ABSTRACT permission posture, which is
# mapped onto whichever permission surface the INSTALLED devin binary actually
# exposes (probed via parser acceptance at launch — see "surface detection"
# below). Two surfaces are known (tests/wrappers/pm-devin/FINDINGS.md):
#
#  * the FOUR-MODE surface (cli.devin.ai docs, captured 2026-06-02):
#    `--permission-mode normal|accept-edits|bypass|autonomous`, OS isolation
#    via the separate `--sandbox` flag (which couples to `autonomous`);
#  * the TWO-MODE surface (live binary `devin 2026.5.26-3`, probed 2026-06-04):
#    `--permission-mode` accepts ONLY `normal` (alias `auto`) and `dangerous`
#    (aliases `yolo`, `bypass`); `autonomous`/`accept-edits` are REJECTED at
#    argv parse (exit 2). `--sandbox` exists independently and "enforces the
#    active Read/Write permission scopes at the OS level".
#
# Abstract modes and their per-surface composition:
#
#   normal        four-mode: --permission-mode normal
#                 two-mode:  --permission-mode normal   (valid on both)
#                 reads auto-approved; writes/shell PROMPT for approval
#                 (blocks in a non-interactive handoff)
#   accept-edits  four-mode: --permission-mode accept-edits
#                 two-mode:  NO equivalent — FAIL CLOSED before launch
#   bypass        four-mode: --permission-mode bypass
#                 two-mode:  --permission-mode bypass   (alias of `dangerous`)
#                 all tool calls auto-approved; NO OS sandbox (unbounded)
#   autonomous    four-mode: --sandbox --permission-mode autonomous
#                 two-mode:  --sandbox --permission-mode dangerous
#                 all tool calls auto-approved, but the OS sandbox bounds the
#                 filesystem/network. Same containment posture on both
#                 surfaces: auto-approval bounded by devin's own OS sandbox.
#
# DEFAULT = "autonomous": the most-restrictive sensible mode that still lets
# the PM→assignee handoff complete with NO human in the loop. It is the direct
# analogue of cartopian-codex defaulting to the `workspace-write` *sandbox*
# (OS-bounded autonomy) rather than `danger-full-access`: same auto-approval as
# `bypass`, but OS-enforced filesystem/network bounds on top. `normal` and
# `accept-edits` are NOT defaults because they block waiting for TTY approval
# on the first write/shell call and would burn to the CARTOPIAN_TIMEOUT
# deadline (exit 124). The `--sandbox` flag autonomous depends on is NOT
# present on every devin build: older binaries predate it and reject it at
# argv parse. It is probed independently of the permission surface (see
# "sandbox-support detection" below); if absent, autonomous DEGRADES to
# `--permission-mode bypass` (the same auto-approve-all posture, minus the OS
# sandbox) with a warning, so the unattended handoff still runs as it always
# has rather than emitting a `--sandbox` flag the binary rejects. The OS
# containment guarantee is simply unavailable on such a build; an operator who
# needs it must update devin to a build that exposes `--sandbox`.
#
# NOTE: devin's local OS `--sandbox` does NOT extend to devin's cloud
# `/handoff` / cloud subagents; this wrapper only sets the flags it passes.
#
# Legacy CARTOPIAN_DEVIN_PERMISSION values stay accepted and are mapped onto
# the abstract modes so existing configs keep working:
#   auto      -> normal   (old "ask before write/execute")
#   dangerous -> bypass   (old "auto-approve all tool calls")
DEVIN_PERMISSION_MODE="${CARTOPIAN_DEVIN_PERMISSION:-autonomous}"
case "$DEVIN_PERMISSION_MODE" in
  auto)      DEVIN_PERMISSION_MODE="normal" ;;
  dangerous) DEVIN_PERMISSION_MODE="bypass" ;;
esac
# Validate against the documented surface; reject anything else fail-closed
# rather than passing a flag value devin would reject at launch.
case "$DEVIN_PERMISSION_MODE" in
  normal|accept-edits|bypass|autonomous) ;;
  *)
    echo "cartopian-devin: error: unknown CARTOPIAN_DEVIN_PERMISSION='$DEVIN_PERMISSION_MODE'" >&2
    echo "  valid: normal | accept-edits | bypass | autonomous (legacy: auto->normal, dangerous->bypass)" >&2
    exit 1
    ;;
esac
# ------------------------------------------------------------------

readonly PROMPT_PATH="${1:-}"

if [[ -z "$PROMPT_PATH" ]]; then
  echo "cartopian-devin: error: missing prompt path argument" >&2
  echo "usage: cartopian-devin <absolute-prompt-path>" >&2
  exit 1
fi

if [[ ! -f "$PROMPT_PATH" ]]; then
  echo "cartopian-devin: error: prompt file not found: $PROMPT_PATH" >&2
  exit 1
fi

if ! command -v devin &>/dev/null; then
  echo "cartopian-devin: error: 'devin' not found in PATH" >&2
  echo "Install: https://docs.devin.ai/" >&2
  exit 1
fi

# --- Permission-surface detection ------------------------------------
# The installed devin binary determines which `--permission-mode` values are
# valid (see the Configuration block above). Probe the binary's ARGV PARSER,
# not its help prose: a parser that ACCEPTS `--permission-mode autonomous`
# (exit 0 with --help appended) is the four-mode surface; one that rejects it
# at parse (exit 2 — the live `devin 2026.5.26-3` behavior) is the two-mode
# surface. Parser acceptance cannot be fooled by help-text wording drift (a
# deprecation note that merely *mentions* "autonomous" would misclassify a
# token grep). Any probe failure — non-zero exit for any reason, including a
# probe killed at the 10s bound — degrades to two-mode, the live-verified
# surface, never to a guessed flag value the binary would reject at launch.
# The probe is wrapped in `timeout` when available so a hanging `devin --help`
# (cloud auth check at startup, broken install) cannot stall the wrapper
# outside the CARTOPIAN_TIMEOUT SSOT deadline, which only covers the launch.
DEVIN_PROBE=(devin --permission-mode autonomous --help)
if command -v timeout &>/dev/null; then
  DEVIN_PROBE=(timeout 10s "${DEVIN_PROBE[@]}")
elif command -v gtimeout &>/dev/null; then
  DEVIN_PROBE=(gtimeout 10s "${DEVIN_PROBE[@]}")
fi
if "${DEVIN_PROBE[@]}" >/dev/null 2>&1; then
  DEVIN_SURFACE="four-mode"
else
  DEVIN_SURFACE="two-mode"
fi

# --- Sandbox-support detection ---------------------------------------
# The surface probe above settles which `--permission-mode` VALUES the binary
# parses; it does NOT establish whether `--sandbox` exists. Older devin builds
# predate the flag entirely and reject it at argv parse (exit 2). `autonomous`
# (the default) composes `--sandbox …`, so on such a binary that launch fails
# with a cryptic parser error. Probe `--sandbox` independently — same
# discipline as the surface probe: parser acceptance of `devin --sandbox
# --help`, a 10s bound, any failure (non-zero exit for any reason, or a probe
# killed at the bound) → treat as UNSUPPORTED. The probe carries no
# `--permission-mode` value so a two-mode binary that DOES support `--sandbox`
# is not misclassified by an unrelated mode-value rejection. The autonomous
# path then degrades to `--permission-mode bypass` (with a warning) rather than
# emitting a flag the binary rejects.
DEVIN_SANDBOX_PROBE=(devin --sandbox --help)
if command -v timeout &>/dev/null; then
  DEVIN_SANDBOX_PROBE=(timeout 10s "${DEVIN_SANDBOX_PROBE[@]}")
elif command -v gtimeout &>/dev/null; then
  DEVIN_SANDBOX_PROBE=(gtimeout 10s "${DEVIN_SANDBOX_PROBE[@]}")
fi
if "${DEVIN_SANDBOX_PROBE[@]}" >/dev/null 2>&1; then
  DEVIN_SANDBOX_SUPPORTED=true
else
  DEVIN_SANDBOX_SUPPORTED=false
fi

PROMPT_PATH_ABS="$(cd "$(dirname "$PROMPT_PATH")" && pwd)/$(basename "$PROMPT_PATH")"

# Derive the optional status-file path now, before any cd, so a relative
# prompt path still resolves. Empty when the prompt is outside a project.
STATUS_PATH="$(cartopian_status_path "$PROMPT_PATH")"

# --- Launch directory ------------------------------------------------
# Assignee CLIs run with cwd set to the Cartopian project root
# (the registered project path). Prompts always live at
# <workspace>/projects/<project-id>/prompts/PROMPT-*.md, so the project
# root is derivable from the prompt path alone.
#
# Override: set CARTOPIAN_LAUNCH_CWD to an absolute or relative path to
# skip auto-resolution. Useful for split-layout, cross-drive, monorepo,
# or per-repo-sandbox setups. A non-existent path is a hard error, not
# a silent fallback.
if [[ -n "${CARTOPIAN_LAUNCH_CWD:-}" ]]; then
  if [[ ! -d "$CARTOPIAN_LAUNCH_CWD" ]]; then
    echo "cartopian-devin: CARTOPIAN_LAUNCH_CWD='$CARTOPIAN_LAUNCH_CWD' is not a directory" >&2
    exit 1
  fi
  LAUNCH_CWD="$(cd "$CARTOPIAN_LAUNCH_CWD" && pwd)"
  cd "$LAUNCH_CWD"
  echo "cartopian-devin: cwd=$LAUNCH_CWD (CARTOPIAN_LAUNCH_CWD override)" >&2
else
  PROMPTS_DIR="$(dirname "$PROMPT_PATH_ABS")"
  PROJECT_DIR="$(dirname "$PROMPTS_DIR")"
  # Launch-cwd: trigger when basename("$PROMPTS_DIR")) == "prompts"
  if [[ "$(basename "$PROMPTS_DIR")" == "prompts" ]]; then
    cd "$PROJECT_DIR"
    echo "cartopian-devin: cwd=$PROJECT_DIR" >&2
  else
    echo "cartopian-devin: prompt is outside a Cartopian project layout; leaving cwd unchanged (set CARTOPIAN_LAUNCH_CWD to override)" >&2
  fi
fi
# --------------------------------------------------------------------

# Build the command, mapping the abstract mode onto the DETECTED surface (see
# the Configuration block). On the four-mode surface `autonomous` requires the
# OS sandbox (the mode is unavailable without `--sandbox`, and `--sandbox` only
# permits autonomous), so pass both — matching the documented example
# `devin --sandbox --permission-mode autonomous`. On the two-mode surface the
# same posture (auto-approve-all bounded by devin's own OS sandbox) is spelled
# `--sandbox --permission-mode dangerous`; `accept-edits` has no two-mode
# equivalent and FAILS CLOSED rather than passing a value devin rejects.
CMD=(devin -p)
case "$DEVIN_PERMISSION_MODE" in
  autonomous)
    if [[ "$DEVIN_SANDBOX_SUPPORTED" != "true" ]]; then
      # This devin build predates `--sandbox`, so OS-bounded autonomy is
      # unavailable. Degrade to the same auto-approve-all posture WITHOUT the
      # sandbox flag — `--permission-mode bypass` (valid on both surfaces) — so
      # the unattended handoff still runs as it always has, rather than failing
      # closed. The OS containment guarantee is gone; warn so the dropped
      # boundary is visible in the handoff logs.
      echo "cartopian-devin: warning: installed devin CLI has no '--sandbox'; running unsandboxed via --permission-mode bypass (auto-approve-all, NO OS containment)" >&2
      CMD+=(--permission-mode bypass)
    elif [[ "$DEVIN_SURFACE" == "four-mode" ]]; then
      CMD+=(--sandbox --permission-mode autonomous)
    else
      CMD+=(--sandbox --permission-mode dangerous)
    fi
    ;;
  accept-edits)
    if [[ "$DEVIN_SURFACE" == "four-mode" ]]; then
      CMD+=(--permission-mode accept-edits)
    else
      echo "cartopian-devin: error: the installed devin CLI exposes no 'accept-edits' permission mode (two-mode surface: normal|dangerous)" >&2
      echo "  choose CARTOPIAN_DEVIN_PERMISSION=normal | bypass | autonomous, or update the devin CLI" >&2
      exit 1
    fi
    ;;
  normal|bypass)
    # Valid spellings on BOTH surfaces (two-mode accepts `normal` as the alias
    # of `auto` and `bypass` as an alias of `dangerous`).
    CMD+=(--permission-mode "$DEVIN_PERMISSION_MODE")
    ;;
esac
# Agent-neutral model selection: dispatch exports CARTOPIAN_MODEL from the
# resolved [handoffs.<role>].model; translate it into devin's --model flag.
# Unset means devin's own default model.
if [[ -n "${CARTOPIAN_MODEL:-}" ]]; then
  CMD+=(--model "$CARTOPIAN_MODEL")
fi
# devin has no effort/thinking-level flag: a configured
# [handoffs.<role>].effort cannot be translated, so it is ignored with a
# notice and devin runs at its own default.
if [[ -n "${CARTOPIAN_EFFORT:-}" ]]; then
  echo "cartopian-devin: devin has no effort/thinking flag; ignoring CARTOPIAN_EFFORT=$CARTOPIAN_EFFORT" >&2
fi
# devin takes the prompt by file path (--prompt-file): pass the operator's
# original prompt file directly. The CLI loads it, so no prompt body reaches the
# command line (and the original is never mutated).
CMD+=(--prompt-file "$PROMPT_PATH_ABS")

# --- OS-enforced deadline (CARTOPIAN_TIMEOUT) -----------------------
# Prepend `timeout` (or `gtimeout` on macOS) so the OS kills the
# upstream process at the configured deadline (default 60m). The PM
# sets CARTOPIAN_TIMEOUT from the resolved [handoffs.<role>].timeout;
# it does not poll or watchdog the running process. SIGTERM at deadline
# returns exit code 124. See protocol/CONVENTIONS.md → Handoffs.
TIMEOUT_DURATION="${CARTOPIAN_TIMEOUT:-60m}"
# Whether an OS timeout wraps the command — lets the status file distinguish
# a deadline kill (exit 124) from a plain non-zero exit.
TIMEOUT_APPLIED=false
if command -v timeout &>/dev/null; then
  CMD=(timeout "$TIMEOUT_DURATION" "${CMD[@]}")
  TIMEOUT_APPLIED=true
elif command -v gtimeout &>/dev/null; then
  CMD=(gtimeout "$TIMEOUT_DURATION" "${CMD[@]}")
  TIMEOUT_APPLIED=true
else
  echo "cartopian-devin: warning: no 'timeout'/'gtimeout' on PATH; running without OS-enforced deadline (macOS: brew install coreutils)" >&2
  TIMEOUT_DURATION="unbounded"
fi
# --------------------------------------------------------------------

echo "cartopian-devin: running devin -p (permission=$DEVIN_PERMISSION_MODE, surface=$DEVIN_SURFACE, sandbox=$DEVIN_SANDBOX_SUPPORTED, timeout=$TIMEOUT_DURATION)" >&2

# Run the assignee (not exec) so we can capture its exit outcome and emit
# the optional status file wait-handoff polls for early-crash detection.
#
# cartopian_run_supervised wraps the run with a report-completion supervisor:
# once the authoritative report file appears, a lingering child (MCP stdio /
# trailing turn) is reaped promptly so a finished handoff exits 0/clean instead
# of idling to the CARTOPIAN_TIMEOUT deadline. The deadline (the single SSOT
# timer, applied above via `timeout`) is untouched — a genuine hang that writes
# no report still hits it (exit 124). The watched report path is the status path
# without its ".status" suffix.
REPORT_PATH="${STATUS_PATH%.status}"
[[ "$REPORT_PATH" == "$STATUS_PATH" ]] && REPORT_PATH=""

set +e
cartopian_run_supervised "$REPORT_PATH" "${CMD[@]}"
ASSIGNEE_EXIT=$CARTOPIAN_ASSIGNEE_EXIT
set -e
cartopian_write_status "$STATUS_PATH" "$ASSIGNEE_EXIT" "$TIMEOUT_APPLIED"
exit "$ASSIGNEE_EXIT"
