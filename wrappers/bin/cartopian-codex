#!/usr/bin/env bash
# cartopian-codex — Cartopian wrapper for the OpenAI Codex CLI.
#
# Usage:  cartopian-codex <absolute-prompt-path>
#
# Reads the prompt file and passes its content to `codex exec` with
# non-interactive flags. Edit the Configuration section below to change
# sandbox scope and other tool-specific settings.
#
# Note on approvals: `codex exec` is non-interactive and has no
# `--approval-mode`/`--ask-for-approval` flag (those live on the
# interactive `codex` command). Autonomy in `exec` mode is controlled by
# the sandbox scope plus `--dangerously-bypass-approvals-and-sandbox`.
# Verified against codex-cli 0.128.0 (`codex exec --help`).
#
# Note on git-repo check: `codex exec` refuses to run unless cwd is
# inside a git repository (or `--skip-git-repo-check` is passed). Under
# the Cartopian launch-cwd convention the cwd is the parent of the
# workspace, which is intentionally not a git repo, so the wrapper
# passes `--skip-git-repo-check` unconditionally. Sandbox safety still
# comes from `--sandbox workspace-write`, which roots writes at the
# launch cwd; it does not depend on cwd being a git repo.
#
# Exit codes:
#   0   — codex completed successfully
#   1   — wrapper error (missing file, missing CLI, bad arguments)
#   *   — upstream codex exit code

set -euo pipefail

# --- Status-file helper (early-crash signal for wait-handoff) --------
# Source the shared helper that emits <report-path>.status on assignee
# exit. Optional: if the helper is missing, degrade to no-op stubs so the
# wrapper still runs (the status file is never a hard requirement).
_CARTOPIAN_WRAPPER_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
if [[ -f "${_CARTOPIAN_WRAPPER_DIR}/_cartopian-status.sh" ]]; then
  # shellcheck source=_cartopian-status.sh
  source "${_CARTOPIAN_WRAPPER_DIR}/_cartopian-status.sh"
else
  cartopian_status_path() { echo ""; }
  cartopian_write_status() { return 0; }
fi
# --------------------------------------------------------------------

# --- Configuration ---------------------------------------------------
# Sandbox scope for model-generated shell commands.
# Allowed values (per `codex exec --help`):
#   read-only           — model cannot write outside its scratch space
#   workspace-write     — model can write inside the working directory
#   danger-full-access  — no filesystem sandbox (effectively unsandboxed)
# Default is workspace-write so coder handoffs can actually edit files.
CODEX_SANDBOX="${CARTOPIAN_CODEX_SANDBOX:-workspace-write}"

# Bypass all approval gates AND the sandbox. EXTREMELY DANGEROUS.
# Only enable inside an externally-sandboxed environment (CI container,
# VM, etc.). Equivalent to `--dangerously-bypass-approvals-and-sandbox`.
CODEX_BYPASS="${CARTOPIAN_CODEX_BYPASS:-false}"
# ------------------------------------------------------------------

readonly PROMPT_PATH="${1:-}"

if [[ -z "$PROMPT_PATH" ]]; then
  echo "cartopian-codex: error: missing prompt path argument" >&2
  echo "usage: cartopian-codex <absolute-prompt-path>" >&2
  exit 1
fi

if [[ ! -f "$PROMPT_PATH" ]]; then
  echo "cartopian-codex: error: prompt file not found: $PROMPT_PATH" >&2
  exit 1
fi

if ! command -v codex &>/dev/null; then
  echo "cartopian-codex: error: 'codex' not found in PATH" >&2
  echo "Install: https://github.com/openai/codex" >&2
  exit 1
fi

PROMPT_CONTENT="$(cat "$PROMPT_PATH")"

# Derive the optional status-file path now, before any cd, so a relative
# prompt path still resolves. Empty when the prompt is outside a project.
STATUS_PATH="$(cartopian_status_path "$PROMPT_PATH")"

# --- Launch directory ------------------------------------------------
# FR-012: assignee CLIs run with cwd set to the Cartopian project root
# (the registered project path). Prompts always live at
# <workspace>/projects/<project-id>/prompts/PROMPT-*.md, so the project
# root is derivable from the prompt path alone.
#
# Override: set CARTOPIAN_LAUNCH_CWD to an absolute or relative path to
# skip auto-resolution. Useful for split-layout, cross-drive, monorepo,
# or per-repo-sandbox setups. A non-existent path is a hard error, not
# a silent fallback.
if [[ -n "${CARTOPIAN_LAUNCH_CWD:-}" ]]; then
  if [[ ! -d "$CARTOPIAN_LAUNCH_CWD" ]]; then
    echo "cartopian-codex: CARTOPIAN_LAUNCH_CWD='$CARTOPIAN_LAUNCH_CWD' is not a directory" >&2
    exit 1
  fi
  LAUNCH_CWD="$(cd "$CARTOPIAN_LAUNCH_CWD" && pwd)"
  cd "$LAUNCH_CWD"
  echo "cartopian-codex: cwd=$LAUNCH_CWD (CARTOPIAN_LAUNCH_CWD override)" >&2
else
  PROMPT_ABS="$(cd "$(dirname "$PROMPT_PATH")" && pwd)/$(basename "$PROMPT_PATH")"
  PROMPTS_DIR="$(dirname "$PROMPT_ABS")"
  PROJECT_DIR="$(dirname "$PROMPTS_DIR")"
  # FR-012 launch-cwd: trigger when basename("$PROMPTS_DIR")) == "prompts"
  if [[ "$(basename "$PROMPTS_DIR")" == "prompts" ]]; then
    cd "$PROJECT_DIR"
    echo "cartopian-codex: cwd=$PROJECT_DIR" >&2
  else
    echo "cartopian-codex: prompt is outside a Cartopian project layout; leaving cwd unchanged (set CARTOPIAN_LAUNCH_CWD to override)" >&2
  fi
fi
# --------------------------------------------------------------------

# --- Access grants (OQ-009) -----------------------------------------
# Read resolved work-root absolute paths via Core CLI. Fail-closed when
# non-empty and per-tool sandbox cannot scope multi-root access. Allow an
# explicit per-invocation bypass via CARTOPIAN_CODEX_UNRESTRICTED=true.
if command -v cartopian &>/dev/null; then
  RC_JSON="$(cartopian resolve-config "$PWD" | head -n 1)"
  if [[ -n "$RC_JSON" ]]; then
    WORK_ROOTS=$(python3 - <<'PY'
import sys, json
try:
    rec = json.loads(sys.stdin.read())
except Exception:
    print("")
    raise SystemExit(0)
wr = rec.get("work_roots") or {}
if isinstance(wr, dict) and wr:
    print("\n".join(str(p) for p in wr.values()))
else:
    print("")
PY
    <<<"$RC_JSON")
    if [[ -n "$WORK_ROOTS" ]]; then
      while IFS= read -r root; do
        [[ -z "$root" ]] && continue
        if [[ ! -d "$root" ]]; then
          echo "[work-root] missing: $root" >&2
          exit 1
        fi
      done <<< "$WORK_ROOTS"
      if [[ "${CARTOPIAN_CODEX_UNRESTRICTED:-false}" != "true" ]]; then
        echo "[work-root] tool cannot scope multi-root access; set CARTOPIAN_CODEX_UNRESTRICTED=true to bypass (dangerous)" >&2
        exit 1
      else
        echo "cartopian-codex: unrestricted mode enabled; proceeding without scoped grants" >&2
      fi
    fi
  fi
fi
# --------------------------------------------------------------------

CMD=(codex exec --skip-git-repo-check)

if [[ "$CODEX_BYPASS" == "true" ]]; then
  CMD+=(--dangerously-bypass-approvals-and-sandbox)
elif [[ -n "$CODEX_SANDBOX" ]]; then
  CMD+=(--sandbox "$CODEX_SANDBOX")
fi

CMD+=("$PROMPT_CONTENT")

# --- OS-enforced deadline (CARTOPIAN_TIMEOUT) -----------------------
# Prepend `timeout` (or `gtimeout` on macOS) so the OS kills the
# upstream process at the configured deadline (default 60m). The PM
# sets CARTOPIAN_TIMEOUT from the resolved [handoffs.<role>].timeout;
# it does not poll or watchdog the running process. SIGTERM at deadline
# returns exit code 124. See protocol/CONVENTIONS.md → Handoffs.
TIMEOUT_DURATION="${CARTOPIAN_TIMEOUT:-60m}"
# Whether an OS timeout wraps the command — lets the status file distinguish
# a deadline kill (exit 124) from a plain non-zero exit.
TIMEOUT_APPLIED=false
if command -v timeout &>/dev/null; then
  CMD=(timeout "$TIMEOUT_DURATION" "${CMD[@]}")
  TIMEOUT_APPLIED=true
elif command -v gtimeout &>/dev/null; then
  CMD=(gtimeout "$TIMEOUT_DURATION" "${CMD[@]}")
  TIMEOUT_APPLIED=true
else
  echo "cartopian-codex: warning: no 'timeout'/'gtimeout' on PATH; running without OS-enforced deadline (macOS: brew install coreutils)" >&2
  TIMEOUT_DURATION="unbounded"
fi
# --------------------------------------------------------------------

if [[ "$CODEX_BYPASS" == "true" ]]; then
  echo "cartopian-codex: running codex exec (bypass=on, sandbox=disabled, skip-git-repo-check=on, timeout=$TIMEOUT_DURATION)" >&2
else
  echo "cartopian-codex: running codex exec (sandbox=$CODEX_SANDBOX, skip-git-repo-check=on, timeout=$TIMEOUT_DURATION)" >&2
fi

# Run the assignee (not exec) so we can capture its exit outcome and emit
# the optional status file wait-handoff polls for early-crash detection.
set +e
"${CMD[@]}"
ASSIGNEE_EXIT=$?
set -e
cartopian_write_status "$STATUS_PATH" "$ASSIGNEE_EXIT" "$TIMEOUT_APPLIED"
exit "$ASSIGNEE_EXIT"
