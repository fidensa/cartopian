#!/usr/bin/env bash
# cartopian-claude — Cartopian wrapper for the Claude Code CLI.
#
# Usage:  cartopian-claude <absolute-prompt-path>
#
# Reads the prompt file and passes its content to `claude -p` with
# non-interactive flags. Edit the Configuration section below to change
# allowed tools, output format, and other tool-specific settings.
#
# Exit codes:
#   0   — claude completed successfully
#   1   — wrapper error (missing file, missing CLI, bad arguments)
#   *   — upstream claude exit code

set -euo pipefail

# --- Status-file helper (early-crash signal for wait-handoff) --------
# Source the shared helper that emits <report-path>.status on assignee
# exit. Optional: if the helper is missing, degrade to no-op stubs so the
# wrapper still runs (the status file is never a hard requirement).
_CARTOPIAN_WRAPPER_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
if [[ -f "${_CARTOPIAN_WRAPPER_DIR}/_cartopian-status.sh" ]]; then
  # shellcheck source=_cartopian-status.sh
  source "${_CARTOPIAN_WRAPPER_DIR}/_cartopian-status.sh"
else
  cartopian_status_path() { echo ""; }
  cartopian_write_status() { return 0; }
  cartopian_report_complete() { return 1; }
  cartopian_run_supervised() { shift; "$@"; CARTOPIAN_ASSIGNEE_EXIT=$?; return 0; }
  cartopian_review_recapture_active() { return 1; }
  cartopian_review_recapture_banner() { return 0; }
  cartopian_extract_work_roots() { echo ""; }
  cartopian_enforce_work_roots() { return 0; }
  cartopian_comment_directive() { echo ""; }
fi
# --------------------------------------------------------------------

# --- Configuration ---------------------------------------------------
# Allowed tools (comma-separated). RESTRICTS which tools claude can use.
# Empty (default) means claude uses its full default tool set, which is
# what an autonomous coder/reviewer handoff needs (Read, Write, Edit,
# Bash, Glob, Grep, etc.).
#   ""               — full default tool set (matches autonomous posture)
#   Read,Write,Bash  — narrow whitelist
#   Read             — read-only
CLAUDE_ALLOWED_TOOLS="${CARTOPIAN_CLAUDE_TOOLS:-}"

# Output format: "text" | "json" | "stream-json"
CLAUDE_OUTPUT_FORMAT="${CARTOPIAN_CLAUDE_FORMAT:-text}"

# Use --bare to skip auto-discovery of hooks/plugins (faster startup)
CLAUDE_BARE="${CARTOPIAN_CLAUDE_BARE:-false}"

# Skip all permission prompts so claude runs non-interactively. Without
# this, claude will hang waiting on TTY input the first time it tries
# to write a file or run a shell command. This matches the autonomy
# posture of cartopian-codex (workspace-write sandbox) and
# cartopian-gemini (--approval-mode yolo). Set to "false" to re-enable
# permission prompts (only useful for interactive debugging).
CLAUDE_SKIP_PERMISSIONS="${CARTOPIAN_CLAUDE_SKIP_PERMS:-true}"
# ------------------------------------------------------------------

readonly PROMPT_PATH="${1:-}"

if [[ -z "$PROMPT_PATH" ]]; then
  echo "cartopian-claude: error: missing prompt path argument" >&2
  echo "usage: cartopian-claude <absolute-prompt-path>" >&2
  exit 1
fi

if [[ ! -f "$PROMPT_PATH" ]]; then
  echo "cartopian-claude: error: prompt file not found: $PROMPT_PATH" >&2
  exit 1
fi

if ! command -v claude &>/dev/null; then
  echo "cartopian-claude: error: 'claude' not found in PATH" >&2
  echo "Install: https://docs.anthropic.com/en/docs/claude-code" >&2
  exit 1
fi

PROMPT_CONTENT="$(cat "$PROMPT_PATH")"

# Prepend the operator-configured comment-volume directive plus the always-on
# management-identifier ban when the mediated launcher set the level. Keeps the
# policy out of the prompt file and applies it at coding time.
if [[ -n "${CARTOPIAN_CODE_COMMENTS:-}" ]]; then
  PROMPT_CONTENT="$(cartopian_comment_directive "$CARTOPIAN_CODE_COMMENTS")"$'\n\n'"$PROMPT_CONTENT"
fi

# Derive the optional status-file path now, before any cd, so a relative
# prompt path still resolves. Empty when the prompt is outside a project.
STATUS_PATH="$(cartopian_status_path "$PROMPT_PATH")"

# --- Launch directory ------------------------------------------------
# Assignee CLIs run with cwd set to the Cartopian project root (the
# registered project path). Prompts always live at
# <workspace>/projects/<project-id>/prompts/PROMPT-*.md, so the project
# root is derivable from the prompt path alone.
#
# Override: set CARTOPIAN_LAUNCH_CWD to an absolute or relative path to
# skip auto-resolution. Useful for split-layout, cross-drive, monorepo,
# or per-repo-sandbox setups. A non-existent path is a hard error, not
# a silent fallback.
if [[ -n "${CARTOPIAN_LAUNCH_CWD:-}" ]]; then
  if [[ ! -d "$CARTOPIAN_LAUNCH_CWD" ]]; then
    echo "cartopian-claude: CARTOPIAN_LAUNCH_CWD='$CARTOPIAN_LAUNCH_CWD' is not a directory" >&2
    exit 1
  fi
  LAUNCH_CWD="$(cd "$CARTOPIAN_LAUNCH_CWD" && pwd)"
  cd "$LAUNCH_CWD"
  echo "cartopian-claude: cwd=$LAUNCH_CWD (CARTOPIAN_LAUNCH_CWD override)" >&2
else
  PROMPT_ABS="$(cd "$(dirname "$PROMPT_PATH")" && pwd)/$(basename "$PROMPT_PATH")"
  PROMPTS_DIR="$(dirname "$PROMPT_ABS")"
  PROJECT_DIR="$(dirname "$PROMPTS_DIR")"
  # Launch-cwd: trigger when basename("$PROMPTS_DIR")) == "prompts"
  if [[ "$(basename "$PROMPTS_DIR")" == "prompts" ]]; then
    cd "$PROJECT_DIR"
    echo "cartopian-claude: cwd=$PROJECT_DIR" >&2
  else
    echo "cartopian-claude: prompt is outside a Cartopian project layout; leaving cwd unchanged (set CARTOPIAN_LAUNCH_CWD to override)" >&2
  fi
fi
# --------------------------------------------------------------------

# --- Access grants ---------------------------------------------------
# Enforce the per-agent work-root scoping guard via the shared helper (so the
# fail-closed contract cannot rot per-wrapper and a new wrapper inherits it).
# The helper sets WORK_ROOTS for the recapture banner below; it fails CLOSED
# (non-zero + a [work-root] stderr line) on a missing or unscopable non-empty
# work-root set, unless the per-tool unrestricted bypass or the agent-neutral
# reviewer-recapture read-only path is active.
#
# NOTE: claude's autonomous posture (--dangerously-skip-permissions) has no
# OS-level path-scoping sandbox; --add-dir scopes which directories its TOOLS may
# access (a tool-layer grant, not a kernel sandbox), so under reviewer recapture
# the read-only-source boundary is honored by contract (no write grant added) but
# is not enforced at a sandbox layer the way codex/gemini do — prefer a sandboxed
# reviewer agent for hard review-integrity guarantees.
#
# Native work-root union scoping: claude scopes a multi-directory union via
# `--add-dir <dir>` ("additional directories to allow tool access to"). The
# launch cwd ($1) is already in scope; add each declared work root ($2..) so
# the agent is scoped to the union (launch cwd ∪ declared work roots). The
# shared guard cartopian_enforce_work_roots calls this hook and appends the
# flags to CARTOPIAN_SCOPE_ARGS, which is injected into the claude command below.
cartopian_tool_scope_union() {
  shift  # launch cwd is already the primary scope
  local _d
  for _d in "$@"; do
    CARTOPIAN_SCOPE_ARGS+=(--add-dir "$_d")
  done
  return 0
}

CARTOPIAN_SCOPE_ARGS=()
if command -v cartopian &>/dev/null || [[ -n "${CARTOPIAN_SCOPE_DIRS:-}" ]]; then
  cartopian_enforce_work_roots "cartopian-claude" "${CARTOPIAN_CLAUDE_UNRESTRICTED:-false}" "CARTOPIAN_CLAUDE_UNRESTRICTED"
fi
# --------------------------------------------------------------------

# Reviewer recapture (agent-neutral): document the exact writable/read-only/
# network scope once, listing any declared read-only source roots.
if cartopian_review_recapture_active; then
  cartopian_review_recapture_banner "cartopian-claude" "$PWD" "${WORK_ROOTS:-}"
fi

CMD=(claude -p)

# Native work-root union scoping (--add-dir per declared root). Injected here, at
# the front, so the trailing flags (e.g. --dangerously-skip-permissions) separate
# the variadic --add-dir values from the positional prompt content.
CMD+=(${CARTOPIAN_SCOPE_ARGS[@]+"${CARTOPIAN_SCOPE_ARGS[@]}"})

if [[ -n "$CLAUDE_ALLOWED_TOOLS" ]]; then
  CMD+=(--allowedTools "$CLAUDE_ALLOWED_TOOLS")
fi

if [[ "$CLAUDE_OUTPUT_FORMAT" != "text" ]]; then
  CMD+=(--output-format "$CLAUDE_OUTPUT_FORMAT")
fi

if [[ "$CLAUDE_BARE" == "true" ]]; then
  CMD+=(--bare)
fi

if [[ "$CLAUDE_SKIP_PERMISSIONS" == "true" ]]; then
  CMD+=(--dangerously-skip-permissions)
fi

# Agent-neutral model selection: dispatch exports CARTOPIAN_MODEL from the
# resolved [handoffs.<role>].model; translate it into claude's --model flag.
# Unset means claude's own default model.
if [[ -n "${CARTOPIAN_MODEL:-}" ]]; then
  CMD+=(--model "$CARTOPIAN_MODEL")
fi

CMD+=("$PROMPT_CONTENT")

# --- OS-enforced deadline (CARTOPIAN_TIMEOUT) -----------------------
# Prepend `timeout` (or `gtimeout` on macOS) so the OS kills the
# upstream process at the configured deadline (default 60m). The PM
# sets CARTOPIAN_TIMEOUT from the resolved [handoffs.<role>].timeout;
# it does not poll or watchdog the running process. SIGTERM at deadline
# returns exit code 124. See protocol/CONVENTIONS.md → Handoffs.
TIMEOUT_DURATION="${CARTOPIAN_TIMEOUT:-60m}"
# Whether an OS timeout wraps the command — lets the status file distinguish
# a deadline kill (exit 124) from a plain non-zero exit.
TIMEOUT_APPLIED=false
if command -v timeout &>/dev/null; then
  CMD=(timeout "$TIMEOUT_DURATION" "${CMD[@]}")
  TIMEOUT_APPLIED=true
elif command -v gtimeout &>/dev/null; then
  CMD=(gtimeout "$TIMEOUT_DURATION" "${CMD[@]}")
  TIMEOUT_APPLIED=true
else
  echo "cartopian-claude: warning: no 'timeout'/'gtimeout' on PATH; running without OS-enforced deadline (macOS: brew install coreutils)" >&2
  TIMEOUT_DURATION="unbounded"
fi
# --------------------------------------------------------------------

TRACE_TOOLS="${CLAUDE_ALLOWED_TOOLS:-default}"
echo "cartopian-claude: running claude -p (tools=$TRACE_TOOLS, skip-perms=$CLAUDE_SKIP_PERMISSIONS, timeout=$TIMEOUT_DURATION)" >&2

# Run the assignee (not exec) so we can capture its exit outcome and emit
# the optional status file wait-handoff polls for early-crash detection.
#
# cartopian_run_supervised wraps the run with a report-completion supervisor:
# once the authoritative report file appears, a lingering child (MCP stdio /
# trailing turn) is reaped promptly so a finished handoff exits 0/clean instead
# of idling to the CARTOPIAN_TIMEOUT deadline. The deadline (the single SSOT
# timer, applied above via `timeout`) is untouched — a genuine hang that writes
# no report still hits it (exit 124). The watched report path is the status path
# without its ".status" suffix.
REPORT_PATH="${STATUS_PATH%.status}"
[[ "$REPORT_PATH" == "$STATUS_PATH" ]] && REPORT_PATH=""

set +e
cartopian_run_supervised "$REPORT_PATH" "${CMD[@]}"
ASSIGNEE_EXIT=$CARTOPIAN_ASSIGNEE_EXIT
set -e
cartopian_write_status "$STATUS_PATH" "$ASSIGNEE_EXIT" "$TIMEOUT_APPLIED"
exit "$ASSIGNEE_EXIT"
