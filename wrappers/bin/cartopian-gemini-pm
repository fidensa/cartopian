#!/usr/bin/env bash
# cartopian-gemini-pm — hard-coded gemini PM containment launch profile (TASK-03-002).
#
# Implements the DEC-001 / FR-002 capability floor for the Google Gemini CLI:
# launches the interactive `gemini` PM session restricted to the fixed Cartopian
# MCP toolset and NOTHING ELSE — no shell, no file read/write/edit, no grep/glob/
# ls, no web fetch/search, no MCP-resource read tools, no skills/sub-agents/
# background processes, no non-Cartopian MCP servers — from an isolated cwd with
# no extra directory grants, BENEATH gemini's own native OS sandbox driven to
# per-tool isolation (the FR-007 Tier-2 depth layer).
#
# This is the PM-facing sibling of `cartopian-gemini` (the autonomous coder/
# reviewer wrapper). It is NOT a drop-in replacement: `cartopian-gemini` runs
# `gemini -p` with the full default tool set so an assignee can edit code and run
# shells; this profile does the opposite and locks the surface down to the
# Cartopian protocol tools only, like `cartopian-claude-pm` does for Claude Code.
#
# How the floor is built (gemini's native mechanisms, no bundled sandbox — NF-001):
#   * Tool removal (Tier-1) — a generated, isolated SYSTEM settings file
#     (GEMINI_CLI_SYSTEM_SETTINGS_PATH, gemini's highest-precedence settings
#     layer) that sets tools.exclude to the full built-in tool list — removing
#     run_shell_command, write_file/read_file/replace, read_many_files, glob,
#     search_file_content, list_directory, web_fetch, google_web_search,
#     save_memory, write_todos, AND the built-in list_mcp_resources /
#     read_mcp_resource tools, plus activate_skill / invoke_agent /
#     list_background_processes / read_background_output / enter_plan_mode /
#     update_topic. Unlike codex, gemini CAN remove its MCP-resource read tools,
#     so the floor reaches a genuine no-read-tool state (no codex-style F1 read
#     residual; gemini's web tools are client-side built-ins removed here too, so
#     no codex-style F1b web residual).
#   * MCP scoping (Tier-1) — the settings file registers ONLY the Cartopian MCP
#     server (the same command as wrappers/etc/mcp-cartopian-only.json) and sets
#     mcp.allowed=["cartopian"]; `--allowed-mcp-server-names cartopian` reinforces
#     it from the command line. The PM's only tools are the Cartopian protocol
#     tools.
#   * Native sandbox depth (Tier-2) — security.toolSandboxing=true from the depth
#     profile wrappers/etc/sandbox-gemini-pm-depth.json drives gemini's OWN
#     per-tool Seatbelt (macOS) sandbox, plus SEATBELT_PROFILE, so a (hypothetical)
#     reappeared built-in tool is confined to the isolated surface and product-
#     repo / work-root writes are denied. This is the per-TOOL sandbox, NOT the
#     whole-process `-s` sandbox (which would starve gemini's own API and the
#     out-of-process MCP server — see the depth profile's whole_process_note).
#
# The floor is HARD-CODED and NOT overridable. This wrapper refuses the gemini
# flags that would re-open the surface (-s/--sandbox, --include-directories,
# --allowed-mcp-server-names, --allowed-tools, --policy, --admin-policy,
# -e/--extensions, --approval-mode, -y/--yolo) so the floor cannot be silently
# weakened from the command line.
#
# Usage:
#   cartopian-gemini-pm                 # interactive contained PM session
#   cartopian-gemini-pm [extra gemini flags...]   # extra non-surface-reopening flags
#
# Exit codes:
#   0   — gemini completed successfully
#   1   — wrapper error (missing CLI/config/auth, refused surface-reopening flag)
#   *   — upstream gemini exit code

set -euo pipefail

# --- Resolve locations ----------------------------------------------------
_PM_WRAPPER_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# Tier-2 native-sandbox DEPTH profile (FR-007). The Cartopian source of truth
# that names gemini's per-tool sandbox toggle + SEATBELT_PROFILE + denied roots;
# this wrapper reads them from it and applies them, and FAILS CLOSED if it is
# absent (so the native-sandbox layer can never be silently dropped). Mirrors how
# cartopian-codex-pm references wrappers/etc/sandbox-codex-pm-depth.json.
SANDBOX_PROFILE="${_PM_WRAPPER_DIR}/../etc/sandbox-gemini-pm-depth.json"
# The Cartopian-only MCP definition (shared with the Claude/codex floors): the
# single source of truth for the cartopian-mcp command the floor settings register.
MCP_CONFIG="${_PM_WRAPPER_DIR}/../etc/mcp-cartopian-only.json"

# Isolated PM surface = the launch cwd. Deliberately NOT the product repo and
# NOT a work root: the contained PM operates on the project only through the
# Cartopian MCP tools (which run out-of-process), never through a filesystem
# tool — there is none in this profile. It is also gemini's WORKSPACE root, so
# writes (if a write tool ever reappeared) are confined here, not to the project.
# Override with CARTOPIAN_PM_SURFACE.
PM_SURFACE="${CARTOPIAN_PM_SURFACE:-${_PM_WRAPPER_DIR}/../var/gemini-pm-surface}"
# Isolated home for the contained PM's generated system settings file. Holds ONLY
# the generated floor settings. Override with CARTOPIAN_GEMINI_PM_HOME.
PM_GEMINI_HOME="${CARTOPIAN_GEMINI_PM_HOME:-${_PM_WRAPPER_DIR}/../var/gemini-pm-home}"

# --- Refuse surface-reopening flags from the command line -----------------
# These are the knobs that would re-open the floor or the native sandbox. Reject
# them (in both `--flag value` and `--flag=value` forms) so the floor is not
# overridable by whatever invokes this wrapper.
for arg in "$@"; do
  case "$arg" in
    -s | --sandbox | --sandbox=* \
    | --include-directories | --include-directories=* \
    | --allowed-mcp-server-names | --allowed-mcp-server-names=* \
    | --allowed-tools | --allowed-tools=* \
    | --policy | --policy=* \
    | --admin-policy | --admin-policy=* \
    | -e | --extensions | --extensions=* \
    | --approval-mode | --approval-mode=* \
    | -y | --yolo \
    | --skip-trust)
      echo "cartopian-gemini-pm: refusing flag '$arg' — the PM containment floor (DEC-001/FR-002) and Tier-2 native-sandbox depth profile (FR-007) are not overridable." >&2
      echo "cartopian-gemini-pm: the floor (isolated system settings with tools.exclude of all built-ins, cartopian-only MCP, and security.toolSandboxing from the depth profile) is fixed; remove the flag." >&2
      exit 1
      ;;
  esac
done

# --- Preconditions (fail closed) ------------------------------------------
if ! command -v gemini &>/dev/null; then
  echo "cartopian-gemini-pm: error: 'gemini' not found in PATH" >&2
  echo "Install: https://github.com/google-gemini/gemini-cli" >&2
  exit 1
fi

# Fail closed: the Tier-2 depth profile must be present, or the native-sandbox
# layer would be silently absent. Never launch the PM without it.
if [[ ! -f "$SANDBOX_PROFILE" ]]; then
  echo "cartopian-gemini-pm: error: native-sandbox depth profile not found: $SANDBOX_PROFILE" >&2
  exit 1
fi

if [[ ! -f "$MCP_CONFIG" ]]; then
  echo "cartopian-gemini-pm: error: cartopian MCP config not found: $MCP_CONFIG" >&2
  exit 1
fi

# Resolve the cartopian-mcp command from the shared MCP config (single source of
# truth) and the toolSandboxing + SEATBELT_PROFILE from the depth profile — both
# via python3 stdlib (NF-001), the same json-in-bash pattern cartopian-codex-pm
# already uses.
CARTOPIAN_MCP_CMD="$(python3 - "$MCP_CONFIG" <<'PY'
import json, sys
cfg = json.load(open(sys.argv[1]))
srv = (cfg.get("mcpServers") or {}).get("cartopian") or {}
print(srv.get("command") or "")
PY
)"
if [[ -z "$CARTOPIAN_MCP_CMD" || ! -x "$CARTOPIAN_MCP_CMD" ]]; then
  echo "cartopian-gemini-pm: error: cartopian-mcp command unresolved or not executable: '$CARTOPIAN_MCP_CMD'" >&2
  exit 1
fi

# --- PM toolchain pinning / identity audit (BL-007 / REVIEW-03-006) --------
# Print the resolved toolchain identity (command, root, VERSION) and FAIL
# CLOSED if it resolves into an editable (git) checkout — the work-root tree
# assignees mutate. CARTOPIAN_PM_TOOLCHAIN_DEV=1 is the loud dev-only opt-out.
if [[ ! -f "${_PM_WRAPPER_DIR}/_cartopian-toolchain.sh" ]]; then
  echo "cartopian-gemini-pm: error: toolchain audit helper not found: ${_PM_WRAPPER_DIR}/_cartopian-toolchain.sh" >&2
  exit 1
fi
# shellcheck source=_cartopian-toolchain.sh
source "${_PM_WRAPPER_DIR}/_cartopian-toolchain.sh"
cartopian_pm_toolchain_audit "cartopian-gemini-pm" "$MCP_CONFIG" "$CARTOPIAN_MCP_CMD"

# Read the depth-layer sandbox controls. Fail closed if toolSandboxing is not
# enabled (the depth layer would not actually constrain a reappeared tool).
DEPTH_TOOL_SANDBOX="$(python3 - "$SANDBOX_PROFILE" <<'PY'
import json, sys
p = json.load(open(sys.argv[1]))
val = p.get("tool_sandboxing")
if val is None:
    val = (p.get("gemini_settings") or {}).get("security", {}).get("toolSandboxing")
if val is not True:
    sys.exit("tool-sandboxing-not-enabled")
print("true")
PY
)" || { echo "cartopian-gemini-pm: error: depth profile does not enable security.toolSandboxing: $SANDBOX_PROFILE" >&2; exit 1; }

DEPTH_SEATBELT="$(python3 - "$SANDBOX_PROFILE" <<'PY'
import json, sys
p = json.load(open(sys.argv[1]))
print(p.get("seatbelt_profile") or "restrictive-open")
PY
)"

# --- Build the isolated SYSTEM settings (hard-coded floor) -----------------
# Regenerated every launch so the floor cannot drift from a stale on-disk copy.
# GEMINI_CLI_SYSTEM_SETTINGS_PATH is gemini's highest-precedence settings layer,
# so this overrides the user's ~/.gemini and any project .gemini settings.
mkdir -p "$PM_GEMINI_HOME"
chmod 700 "$PM_GEMINI_HOME" 2>/dev/null || true
GEMINI_SYSTEM_SETTINGS="$PM_GEMINI_HOME/system-settings.json"

python3 - "$GEMINI_SYSTEM_SETTINGS" "$CARTOPIAN_MCP_CMD" <<'PY'
import json, sys
out_path, mcp_cmd = sys.argv[1], sys.argv[2]
# The DEC-001/FR-002 floor: remove EVERY built-in tool (gemini self-reports a
# catalog superset; tools.exclude removes them from the enforced surface), allow
# ONLY the cartopian MCP server, and enable the Tier-2 per-tool sandbox.
settings = {
    "tools": {
        "exclude": [
            "run_shell_command", "read_file", "write_file", "replace",
            "read_many_files", "glob", "search_file_content", "grep_search",
            "list_directory", "web_fetch", "google_web_search", "save_memory",
            "write_todos", "list_mcp_resources", "read_mcp_resource",
            "activate_skill", "invoke_agent", "list_background_processes",
            "read_background_output", "enter_plan_mode", "update_topic",
        ]
    },
    "mcp": {"allowed": ["cartopian"]},
    "mcpServers": {
        "cartopian": {
            "command": mcp_cmd,
            "args": [],
            "env": {"CARTOPIAN_PM_CONTAINED": "1"},
        }
    },
    "security": {
        "auth": {"selectedType": "oauth-personal"},
        "toolSandboxing": True,
    },
}
with open(out_path, "w") as f:
    json.dump(settings, f, indent=2)
PY
chmod 600 "$GEMINI_SYSTEM_SETTINGS" 2>/dev/null || true

# --- Containment signal (FR-013 fail-closed git guard) --------------------
# Mark this PM as contained so resolve-config / next-action can fail closed on
# git.pm_owns_product_branches=true under containment. Belt-and-suspenders with
# the MCP server env above.
export CARTOPIAN_PM_CONTAINED=1
export GEMINI_CLI_SYSTEM_SETTINGS_PATH="$GEMINI_SYSTEM_SETTINGS"
# Drive gemini's native per-tool Seatbelt selection (Tier-2 depth).
export SEATBELT_PROFILE="$DEPTH_SEATBELT"

mkdir -p "$PM_SURFACE"
PM_SURFACE="$(cd "$PM_SURFACE" && pwd)"

echo "cartopian-gemini-pm: contained PM launch profile (DEC-001/FR-002 floor)" >&2
echo "cartopian-gemini-pm: cwd=$PM_SURFACE  system-settings=$GEMINI_SYSTEM_SETTINGS  tools=cartopian-only (all built-ins excluded)" >&2
echo "cartopian-gemini-pm: native-sandbox depth (FR-007) = $SANDBOX_PROFILE  toolSandboxing=true  SEATBELT_PROFILE=$DEPTH_SEATBELT" >&2

# Launch the interactive contained PM session from the isolated surface. exec so
# the PM session owns the terminal. The floor lives in the system settings file;
# the per-tool sandbox is security.toolSandboxing; cwd is the isolated surface;
# --skip-trust trusts ONLY this isolated, content-free surface (the floor already
# removes every tool, so trusting it grants nothing); --allowed-mcp-server-names
# reinforces the cartopian-only MCP scope. NEVER -s/--sandbox, NEVER --add-dir.
cd "$PM_SURFACE"
exec gemini --skip-trust --allowed-mcp-server-names cartopian --approval-mode yolo "$@"
