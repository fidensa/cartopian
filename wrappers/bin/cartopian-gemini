#!/usr/bin/env bash
# cartopian-gemini — Cartopian wrapper for the Google Gemini CLI.
#
# Usage:  cartopian-gemini <absolute-prompt-path>
#
# Reads the prompt file and passes its content to `gemini -p` with
# non-interactive flags. Edit the Configuration section below to change
# tool-specific settings.
#
# Exit codes:
#   0   — gemini completed successfully
#   1   — wrapper error (missing file, missing CLI, bad arguments)
#   *   — upstream gemini exit code

set -euo pipefail

# --- Status-file helper (early-crash signal for wait-handoff) --------
# Source the shared helper that emits <report-path>.status on assignee
# exit. Optional: if the helper is missing, degrade to no-op stubs so the
# wrapper still runs (the status file is never a hard requirement).
_CARTOPIAN_WRAPPER_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
if [[ -f "${_CARTOPIAN_WRAPPER_DIR}/_cartopian-status.sh" ]]; then
  # shellcheck source=_cartopian-status.sh
  source "${_CARTOPIAN_WRAPPER_DIR}/_cartopian-status.sh"
else
  cartopian_status_path() { echo ""; }
  cartopian_write_status() { return 0; }
  cartopian_report_complete() { return 1; }
  cartopian_run_supervised() { shift; "$@"; CARTOPIAN_ASSIGNEE_EXIT=$?; return 0; }
  cartopian_review_recapture_active() { return 1; }
  cartopian_review_recapture_banner() { return 0; }
  cartopian_extract_work_roots() { echo ""; }
  cartopian_enforce_work_roots() { return 0; }
fi
# --------------------------------------------------------------------

# --- Configuration ---------------------------------------------------
# Approval mode (modern gemini CLI). One of:
#   default    — prompt for approval on every tool call
#   auto_edit  — auto-approve edit tools, prompt for shell
#   yolo       — auto-approve everything (equivalent to -y)
#   plan       — read-only planning mode
# Leave empty to fall back to the legacy --yolo / -y mechanism below.
GEMINI_APPROVAL_MODE="${CARTOPIAN_GEMINI_APPROVAL:-yolo}"

# Legacy YOLO toggle. Used only if GEMINI_APPROVAL_MODE is empty.
#   "true"  — pass -y (auto-approve everything)
#   "false" — let gemini use its default behavior
GEMINI_AUTO_YES="${CARTOPIAN_GEMINI_YES:-true}"

# Sandbox toggle. gemini's `-s/--sandbox` is a BOOLEAN flag, not a
# value flag — it just enables sandboxed execution.
#   "true"  — pass --sandbox
#   "false" — leave sandbox disabled (gemini default)
GEMINI_SANDBOX="${CARTOPIAN_GEMINI_SANDBOX:-false}"
# ------------------------------------------------------------------

readonly PROMPT_PATH="${1:-}"

if [[ -z "$PROMPT_PATH" ]]; then
  echo "cartopian-gemini: error: missing prompt path argument" >&2
  echo "usage: cartopian-gemini <absolute-prompt-path>" >&2
  exit 1
fi

if [[ ! -f "$PROMPT_PATH" ]]; then
  echo "cartopian-gemini: error: prompt file not found: $PROMPT_PATH" >&2
  exit 1
fi

if ! command -v gemini &>/dev/null; then
  echo "cartopian-gemini: error: 'gemini' not found in PATH" >&2
  echo "Install: https://github.com/google-gemini/gemini-cli" >&2
  exit 1
fi

PROMPT_CONTENT="$(cat "$PROMPT_PATH")"

# Derive the optional status-file path now, before any cd, so a relative
# prompt path still resolves. Empty when the prompt is outside a project.
STATUS_PATH="$(cartopian_status_path "$PROMPT_PATH")"

# --- Launch directory ------------------------------------------------
# Assignee CLIs run with cwd set to the Cartopian project root
# (the registered project path). Prompts always live at
# <workspace>/projects/<project-id>/prompts/PROMPT-*.md, so the project
# root is derivable from the prompt path alone.
#
# Override: set CARTOPIAN_LAUNCH_CWD to an absolute or relative path to
# skip auto-resolution. Useful for split-layout, cross-drive, monorepo,
# or per-repo-sandbox setups. A non-existent path is a hard error, not
# a silent fallback.
if [[ -n "${CARTOPIAN_LAUNCH_CWD:-}" ]]; then
  if [[ ! -d "$CARTOPIAN_LAUNCH_CWD" ]]; then
    echo "cartopian-gemini: CARTOPIAN_LAUNCH_CWD='$CARTOPIAN_LAUNCH_CWD' is not a directory" >&2
    exit 1
  fi
  LAUNCH_CWD="$(cd "$CARTOPIAN_LAUNCH_CWD" && pwd)"
  cd "$LAUNCH_CWD"
  echo "cartopian-gemini: cwd=$LAUNCH_CWD (CARTOPIAN_LAUNCH_CWD override)" >&2
else
  PROMPT_ABS="$(cd "$(dirname "$PROMPT_PATH")" && pwd)/$(basename "$PROMPT_PATH")"
  PROMPTS_DIR="$(dirname "$PROMPT_ABS")"
  PROJECT_DIR="$(dirname "$PROMPTS_DIR")"
  # launch-cwd: trigger when basename("$PROMPTS_DIR")) == "prompts"
  if [[ "$(basename "$PROMPTS_DIR")" == "prompts" ]]; then
    cd "$PROJECT_DIR"
    echo "cartopian-gemini: cwd=$PROJECT_DIR" >&2
  else
    echo "cartopian-gemini: prompt is outside a Cartopian project layout; leaving cwd unchanged (set CARTOPIAN_LAUNCH_CWD to override)" >&2
  fi
fi
# --------------------------------------------------------------------

# --- Access grants -----------------------------------------
# Enforce the per-agent work-root scoping guard via the shared helper (so the
# fail-closed contract cannot rot per-wrapper and a new wrapper inherits it).
# The helper sets WORK_ROOTS for the recapture banner below; it fails CLOSED
# (non-zero + a [work-root] stderr line) on a missing or unscopable non-empty
# work-root set, unless the per-tool unrestricted bypass or the agent-neutral
# reviewer-recapture read-only path is active. Under recapture, gemini's OS
# sandbox (forced on below) roots writes at the launch cwd + temp, keeping the
# source work root read-only.
#
# Native work-root union scoping: gemini scopes a multi-directory
# union via `--include-directories <dirs>` ("additional directories to include in
# the workspace", comma-separated). The launch cwd ($1) is the primary workspace
# dir; add each declared work root ($2..) so the workspace is the union (launch
# cwd ∪ declared work roots). The shared guard cartopian_enforce_work_roots calls
# this hook and appends the flag to CARTOPIAN_SCOPE_ARGS, injected into the gemini
# command below.
cartopian_tool_scope_union() {
  shift  # launch cwd is already the primary workspace dir
  local _joined="" _d
  for _d in "$@"; do
    if [ -n "$_joined" ]; then _joined="${_joined},${_d}"; else _joined="$_d"; fi
  done
  [ -n "$_joined" ] && CARTOPIAN_SCOPE_ARGS+=(--include-directories "$_joined")
  return 0
}

CARTOPIAN_SCOPE_ARGS=()
if command -v cartopian &>/dev/null; then
  cartopian_enforce_work_roots "cartopian-gemini" "${CARTOPIAN_GEMINI_UNRESTRICTED:-false}" "CARTOPIAN_GEMINI_UNRESTRICTED"
fi
# --------------------------------------------------------------------

# Reviewer recapture (agent-neutral): force gemini's OS sandbox ON so writes are
# confined to the launch cwd (+ temp) and the reviewed source work root stays
# read-only, while the sandbox retains egress for live probe re-capture. This
# adds egress/isolation only; it never widens the writable filesystem scope.
if cartopian_review_recapture_active; then
  GEMINI_SANDBOX=true
  cartopian_review_recapture_banner "cartopian-gemini" "$PWD" "${WORK_ROOTS:-}"
fi

# Build the command. Flags must precede -p so gemini receives the prompt
# content as -p's value.
CMD=(gemini)

if [[ -n "$GEMINI_APPROVAL_MODE" ]]; then
  CMD+=(--approval-mode "$GEMINI_APPROVAL_MODE")
elif [[ "$GEMINI_AUTO_YES" == "true" ]]; then
  CMD+=(-y)
fi

if [[ "$GEMINI_SANDBOX" == "true" ]]; then
  CMD+=(--sandbox)
fi

# Agent-neutral model selection: dispatch exports CARTOPIAN_MODEL from the
# resolved [handoffs.<role>].model; translate it into gemini's --model flag.
# Unset means gemini's own default model.
if [[ -n "${CARTOPIAN_MODEL:-}" ]]; then
  CMD+=(--model "$CARTOPIAN_MODEL")
fi

# Native work-root union scoping: add the declared roots to the workspace. Placed
# before -p so the prompt is unambiguously -p's value.
CMD+=(${CARTOPIAN_SCOPE_ARGS[@]+"${CARTOPIAN_SCOPE_ARGS[@]}"})

CMD+=(-p "$PROMPT_CONTENT")

# --- OS-enforced deadline (CARTOPIAN_TIMEOUT) -----------------------
# Prepend `timeout` (or `gtimeout` on macOS) so the OS kills the
# upstream process at the configured deadline (default 60m). The PM
# sets CARTOPIAN_TIMEOUT from the resolved [handoffs.<role>].timeout;
# it does not poll or watchdog the running process. SIGTERM at deadline
# returns exit code 124. See protocol/CONVENTIONS.md → Handoffs.
TIMEOUT_DURATION="${CARTOPIAN_TIMEOUT:-60m}"
# Whether an OS timeout wraps the command — lets the status file distinguish
# a deadline kill (exit 124) from a plain non-zero exit.
TIMEOUT_APPLIED=false
if command -v timeout &>/dev/null; then
  CMD=(timeout "$TIMEOUT_DURATION" "${CMD[@]}")
  TIMEOUT_APPLIED=true
elif command -v gtimeout &>/dev/null; then
  CMD=(gtimeout "$TIMEOUT_DURATION" "${CMD[@]}")
  TIMEOUT_APPLIED=true
else
  echo "cartopian-gemini: warning: no 'timeout'/'gtimeout' on PATH; running without OS-enforced deadline (macOS: brew install coreutils)" >&2
  TIMEOUT_DURATION="unbounded"
fi
# --------------------------------------------------------------------

if [[ -n "$GEMINI_APPROVAL_MODE" ]]; then
  echo "cartopian-gemini: running gemini -p (approval=$GEMINI_APPROVAL_MODE, timeout=$TIMEOUT_DURATION)" >&2
else
  echo "cartopian-gemini: running gemini -p (yolo=$GEMINI_AUTO_YES, timeout=$TIMEOUT_DURATION)" >&2
fi

# Run the assignee (not exec) so we can capture its exit outcome and emit
# the optional status file wait-handoff polls for early-crash detection.
#
# cartopian_run_supervised wraps the run with a report-completion supervisor:
# once the authoritative report file appears, a lingering child (MCP stdio /
# trailing turn) is reaped promptly so a finished handoff exits 0/clean instead
# of idling to the CARTOPIAN_TIMEOUT deadline. The deadline (the single SSOT
# timer, applied above via `timeout`) is untouched — a genuine hang that writes
# no report still hits it (exit 124). The watched report path is the status path
# without its ".status" suffix.
REPORT_PATH="${STATUS_PATH%.status}"
[[ "$REPORT_PATH" == "$STATUS_PATH" ]] && REPORT_PATH=""

set +e
cartopian_run_supervised "$REPORT_PATH" "${CMD[@]}"
ASSIGNEE_EXIT=$CARTOPIAN_ASSIGNEE_EXIT
set -e
cartopian_write_status "$STATUS_PATH" "$ASSIGNEE_EXIT" "$TIMEOUT_APPLIED"
exit "$ASSIGNEE_EXIT"
